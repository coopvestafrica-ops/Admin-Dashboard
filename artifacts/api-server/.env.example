# ---------------------------------------------------------------------------
# Admin API server environment variables
# ---------------------------------------------------------------------------

# Postgres connection for admin-only data (organizations, payroll, admin users,
# roles, feature flags, audit logs, etc). Member/loan/wallet/savings data is
# NOT stored here anymore; it lives in the mobile backend's Supabase project
# and is read over HTTP via the variables below.
DATABASE_URL=postgresql://user:password@host:5432/coopvest

# Session signing secret (use a long random string in production).
SESSION_SECRET=change-me-to-a-long-random-string

# Port the Express API listens on.
PORT=8080

# ---------------------------------------------------------------------------
# Mobile backend (Coopvest-App) integration
# ---------------------------------------------------------------------------
# Base URL of the mobile backend. The admin API proxies member-facing routes
# (members, loans, wallets, savings, notifications, support tickets, audit
# logs, dashboard overview) to `${MOBILE_API_BASE_URL}/api/v2/admin/*`.
#   - Local dev:   http://localhost:5000
#   - Staging:     https://coopvest-app-staging.example.com
#   - Production:  https://api.coopvest.africa
MOBILE_API_BASE_URL=http://localhost:5000

# Service token presented as the `X-Service-Token` header on every cross-
# backend request. This MUST match `ADMIN_SERVICE_TOKEN` (or whatever the
# mobile backend expects in `requireServiceToken` middleware) on the mobile
# side. Rotate both together.
MOBILE_API_SERVICE_TOKEN=change-me-to-match-mobile-backend
