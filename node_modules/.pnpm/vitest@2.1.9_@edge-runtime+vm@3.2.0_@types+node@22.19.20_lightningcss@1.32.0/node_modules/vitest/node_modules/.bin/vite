#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/workspace/project/Admin-Dashboard/node_modules/.pnpm/vite@5.4.21_@types+node@22.19.20_lightningcss@1.32.0/node_modules/vite/node_modules:/workspace/project/Admin-Dashboard/node_modules/.pnpm/vite@5.4.21_@types+node@22.19.20_lightningcss@1.32.0/node_modules:/workspace/project/Admin-Dashboard/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/workspace/project/Admin-Dashboard/node_modules/.pnpm/vite@5.4.21_@types+node@22.19.20_lightningcss@1.32.0/node_modules/vite/node_modules:/workspace/project/Admin-Dashboard/node_modules/.pnpm/vite@5.4.21_@types+node@22.19.20_lightningcss@1.32.0/node_modules:/workspace/project/Admin-Dashboard/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../vite/bin/vite.js" "$@"
else
  exec node  "$basedir/../../../vite/bin/vite.js" "$@"
fi
