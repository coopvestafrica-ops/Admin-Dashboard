{
  "version": 2,
  "installCommand": "corepack enable && corepack prepare pnpm@9 --activate && pnpm install --ignore-scripts",
  "buildCommand": "cd artifacts/coopvest-dashboard && npx vite build --config vite.config.ts",
  "outputDirectory": "artifacts/coopvest-dashboard/dist/public",
  "framework": "vite",
  "routes": [
    { "src": "/api/v1/admin/(.*)", "dest": "https://coopvest-api.onrender.com/api/v1/admin/$1" },
    { "src": "/api/v2/admin/(.*)", "dest": "https://coopvest-api.onrender.com/api/v2/admin/$1" },
    { "src": "/api/(.*)", "dest": "https://coopvest-api.onrender.com/api/v2/admin/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}