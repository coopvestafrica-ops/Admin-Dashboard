{
  "version": 2,
  "installCommand": "corepack enable && corepack prepare pnpm@9 --activate && pnpm install --ignore-scripts",
  "buildCommand": "cd artifacts/coopvest-dashboard && npx vite build --config vite.config.ts",
  "outputDirectory": "artifacts/coopvest-dashboard/dist/public",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/v1/admin/(.*)", "destination": "https://coopvest-api.onrender.com/api/v1/admin/$1" },
    { "source": "/api/v2/admin/(.*)", "destination": "https://coopvest-api.onrender.com/api/v2/admin/$1" },
    { "source": "/api/(.*)", "destination": "https://coopvest-api.onrender.com/api/v2/admin/$1" }
  ]
}