{
  "version": 2,
  "installCommand": "corepack enable && corepack prepare pnpm@9 --activate && pnpm install --ignore-scripts",
  "buildCommand": "pnpm --filter @workspace/coopvest-dashboard run build",
  "outputDirectory": "artifacts/coopvest-dashboard/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://coopvest-api-v3.onrender.com/api/:path*" }
  ]
}