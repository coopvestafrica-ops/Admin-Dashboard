{
  "version": 2,
  "installCommand": "corepack enable && pnpm@9 install --ignore-scripts",
  "buildCommand": "pnpm@9 --filter @workspace/api-server run build && pnpm@9 --filter @workspace/coopvest-dashboard run build",
  "outputDirectory": "artifacts/coopvest-dashboard/dist/public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api-server/dist/index.mjs", "headers": { "Content-Type": "application/json" } },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ]
}