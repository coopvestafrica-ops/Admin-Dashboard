{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/coopvest-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "artifacts/coopvest-dashboard/dist/public" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/artifacts/coopvest-dashboard/dist/public/$1" }
  ]
}
