{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/src/index.ts"
    }
  ],
  "installCommand": "cd artifacts/api-server && npm install --legacy-peer-deps",
  "buildCommand": "cd artifacts/api-server && npm run build"
}
