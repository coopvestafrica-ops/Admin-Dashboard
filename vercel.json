{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/coopvest-dashboard/dist",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/artifacts/api-server/dist/index.mjs" },
    { "src": "/sw\\.(.*)", "dest": "/sw.$1" },
    { "src": "/workbox-(.*)", "dest": "/workbox-$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/favicon\\.ico", "dest": "/favicon.ico" },
    { "src": "/(.*)", "dest": "/index.html", "status": 200 }
  ]
}
