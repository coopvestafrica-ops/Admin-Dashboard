{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/coopvest-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    },
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/artifacts/api-server/src/index.ts" },
    { "src": "/(.*)", "dest": "/artifacts/coopvest-dashboard/dist/public/$1", "status": 200 }
  ],
  "buildCommand": "cd artifacts/coopvest-dashboard && npm ci && npm run build"
}
