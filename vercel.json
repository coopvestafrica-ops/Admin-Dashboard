{
  "version": 2,
  "buildCommand": "cd artifacts/api-server && npm install && npm run build",
  "installCommand": "cd artifacts/api-server && npm install",
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/artifacts/api-server/dist/index.mjs"
    }
  ]
}
