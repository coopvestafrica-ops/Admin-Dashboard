{
  "version": 2,
  "installCommand": "cd artifacts/api-server && npm install && cd ../coopvest-dashboard && npm install",
  "buildCommand": "cd artifacts/api-server && npm run build && cd ../coopvest-dashboard && npm run build",
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    },
    {
      "src": "/assets/(.*)",
      "dest": "artifacts/coopvest-dashboard/dist/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/coopvest-dashboard/dist/public/index.html"
    }
  ]
}
