{
  "version": 2,
  "buildCommand": "cd artifacts/api-server && npm install && npm run build && cd ../coopvest-dashboard && npm install && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "artifacts/coopvest-dashboard/dist/public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api-server/dist/index.mjs", "headers": { "Content-Type": "application/json" } },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ]
}